# .host-software — the Where room recipe. One [software "<name>"] stanza per
# component. The trees are gitignored (materialised locally by
# `host-lifecycle software --materialize`); this recipe is the audit anchor.
[software "calx-mill"]
    url       = https://github.com/slartibardfast/calx-mill.git
    pin       = 1f648db6fc64792e70595be5e71da262387eb4ba
    branch    = main
    build     = cargo build --release --locked
    toolchain = rust-1.96.1
    deploy    = main
    artifact  = target/release/calx-mill f3694ff6c31c8bb6249314dbb7f0320cc457c67b27c3f4d473687c2761b1a223

# The gating tool. Its source is also the tools/host-lint submodule (for skills +
# reference); recorded here so --install-hooks builds the verified binary and
# installs the commit hooks. Its .allium is discharged by the host-lint repo's own
# CI (it self-verifies), not re-wired here.
[software "host-lint"]
    url       = https://github.com/connollydavid/host-lint.git
    pin       = 241a870b52325bb261724c567ba175622895bf8d
    branch    = main
    build     = cargo build --release --locked
    toolchain = rust-1.96.1
    deploy    = main
    artifact  = target/release/host-lint 941a47eb5665071144a1452a071de0f1bea3639600f4e55d171bd5439a630f98
    hooks     = pre-commit

